<Page x:Class="DemoSimple.AppData.UI.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoSimple.AppData.UI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ListBox DisplayMemberPath="Login" x:Name="UsersListBox" SelectionChanged="UsersListBox_SelectionChanged"></ListBox>
        <StackPanel Grid.Column="1">
            <StackPanel x:Name="EditPanel" Margin="10" IsEnabled="False">
                <Label>
                    Логин:
                </Label>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}">
                    
                </TextBox>
                <Label>Пароль:</Label>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">

                </TextBox>
                <ComboBox x:Name="RoleComboBox" Margin="0,10,0,0" DisplayMemberPath="Name" 
                      SelectedValuePath="RoleID" 
                      SelectedValue="{Binding UserRole, UpdateSourceTrigger=PropertyChanged}">
                    
                </ComboBox>
                <Label>
                    Колиечство неудачных попыток входа:
                </Label>
                <TextBox Text="{Binding FailedAttempts, UpdateSourceTrigger=PropertyChanged}">

                </TextBox>
                <CheckBox Margin="0,10,0,10" IsChecked="{Binding IsBlocked, UpdateSourceTrigger=PropertyChanged}">Заблокирован?</CheckBox>
                <Button x:Name="DeleteButton" Margin="0,0,0,10" Click="DeleteButton_Click">Удалить</Button>
                <Button x:Name="SaveChanges" Click="SaveChanges_Click">Сохранить изменения</Button>
            </StackPanel>
            <Separator></Separator>
            <StackPanel Margin="10">
                <Button x:Name="AddUser" Margin="0,10,0,10" Click="AddUser_Click">
                    Добавить пользователя
                </Button>
                <Button x:Name="Exit" Click="Exit_Click">
                    Выйти
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
