<Application x:Class="DemoSimple.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DemoSimple"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="PrimaryHoverColor" Color="#106EBE"/>
        <SolidColorBrush x:Key="BgColor" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="TextColor" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#D1D1D1"/>

        <Style TargetType="Page">
            <Setter Property="Background" Value="{StaticResource BgColor}"/>
            <Setter Property="TextElement.FontFamily" Value="Segoe UI"/>
            <Setter Property="TextElement.FontSize" Value="14"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource TextColor}"/>
        </Style>
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgColor}"/>
            <Setter Property="TextElement.FontFamily" Value="Segoe UI"/>
            <Setter Property="TextElement.FontSize" Value="14"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,5,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>

        <Style TargetType="Control" x:Key="BaseInputStyle">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource BaseInputStyle}" />
        <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseInputStyle}" />
        <Style TargetType="ComboBox" BasedOn="{StaticResource BaseInputStyle}">
            <Setter Property="Padding" Value="4,6"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
